# =============================================================================
# 【重要】敏感配置模板 - 请勿直接在此文件中填写真实密钥
# =============================================================================
# 使用方式：
#   1. 复制此文件为 application-secret.yml
#   2. 填写真实的 API 密钥和敏感配置
#   3. application-secret.yml 已加入 .gitignore，不会被提交到 Git
# =============================================================================

# ==================== Spring AI - DeepSeek API 配置 ====================
spring:
  ai:
    openai:
      # DeepSeek API 密钥（从 https://platform.deepseek.com 获取）
      api-key: sk-your-deepseek-api-key-here

# ==================== 其他 AI 服务 API 密钥（备用） ====================
# 如果后续需要切换其他 OpenAI 兼容服务，替换上面的 api-key 即可
# 例如：
#   api-key: sk-your-openai-api-key
#   base-url: https://api.openai.com/v1
