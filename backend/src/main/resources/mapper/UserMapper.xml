<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aicompanion.mapper.UserMapper">

    <!--
        用户动态搜索
        - 默认过滤 deleted = 0（逻辑删除标记）
        - role 非空时追加角色筛选
        - keyword 非空时按用户名/昵称模糊搜索
        - 结果按创建时间倒序排列
    -->
    <select id="searchUsers" resultType="com.aicompanion.model.entity.User">
        SELECT id, username, password, email, phone, nickname, avatar, role, status, create_time, update_time
        FROM sys_user
        <where>
            deleted = 0
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (username LIKE CONCAT('%', #{keyword}, '%')
                     OR nickname LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
